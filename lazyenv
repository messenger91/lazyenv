}

if [[ "$1" == "help" || "$1" == "--help" || "$1" == "-help" || "$1" == "" ]]; then
    print_banner
    G="\033[0;32m"; N="\033[0m"
    echo -e "
Commands:
    ${G}install${N} {name} - install tool by script name
    ${G}run-util${N} {name} - run utility by name
    ${G}github-sync${N} - sync github repos
    ${G}gitlab-sync${N} - sync gitlab repos

    ${G}docker-net${N} - create docker bridge network (172.23.0.0/24)
    ${G}docker-container-build${N} {service} | ${G}dcb${N} {service} - build service docker container
    ${G}docker-container-update${N} {service} | ${G}dcu${N} {service} - update service docker container
    ${G}docker-container-ip${N} {name} | ${G}dci${N} {name} - inspect docker container ip

    ${G}pg-dump${N} {db} - dump postgres database
    ${G}pg-restore${N} {db} {file} - restore postgres database from dump
    ${G}psql-restore${N} {db} {file} - restore postgres database from sql
    ${G}pg-list${N} - list available dumps
    ${G}pg-copy${N} - copy dumps from containers to pg_dump/
    ${G}pg-log${N} [--tail] - follow dump log (or show last 10 lines)

    ${G}mysql-dump${N} {db} - dump mysql database
    ${G}mysql-restore${N} {db} {file} - restore mysql database from dump
    ${G}mysql-log${N} [--tail] - follow mysql dump log (or show last 10 lines)

    ${G}mongodump${N} {db} - dump mongodb
    ${G}mongorestore${N} {db} {date} - restore mongodb
"
fi


if [[ "$1" == "install" ]]; then
    bash $FOLDER/scripts/install/${2}.sh
fi

if [[ "$1" == "run-util" ]]; then
    cd scripts/utils && bash ${2}.sh
fi

if [[ "$1" == "github-sync" ]]; then
   cd scripts/utils && bash github-repos.sh
fi

if [[ "$1" == "gitlab-sync" ]]; then
   cd scripts/utils && bash gitlab-repos.sh
fi

if [[ "$1" == "docker-net" ]]; then
    bash docker/network.sh
fi

if [[ "$1" == "docker-container-build" || "$1" == "dcb" ]]; then
    cd docker/${2} && bash build.sh
fi

if [[ "$1" == "docker-container-update" || "$1" == "dcu" ]]; then
    cd docker/${2} && bash update.sh
fi

if [[ "$1" == "docker-container-ip" || "$1" == "dci" ]]; then
    docker inspect -f '{{range.NetworkSettings.Networks}}{{.IPAddress}}; {{end}}' ${2}
fi

if [[ "$1" == "pg-dump" ]]; then
   docker exec -d postgres bash pg_dump.sh ${2}
fi

if [[ "$1" == "pg-restore" ]]; then
   docker exec -d postgres bash pg_restore.sh ${2} ${3}
fi

if [[ "$1" == "psql-restore" ]]; then
   docker exec -d postgres bash psql_restore.sh ${2} ${3}
fi

if [[ "$1" == "pg-list" ]]; then
    cd $FOLDER/pg_dump
    for file in *; do
        if [ -f "$file" ]; then
            size=$(ls -lh "$file" | awk '{print $5}')
            echo "$file [$size]"
        fi
    done
fi

if [[ "$1" == "mongodump" ]]; then
   docker exec -d mongo bash mongodump.sh ${2}
fi

if [[ "$1" == "mongorestore" ]]; then
   docker exec -d mongo bash mongorestore.sh ${2} ${3}
fi

if [[ "$1" == "mysql-dump" ]]; then
   docker exec -d mysql bash mysql_dump.sh ${2}
fi

if [[ "$1" == "mysql-restore" ]]; then
   docker exec -d mysql bash mysql_restore.sh ${2} ${3}
fi

if [[ "$1" == "mysql-log" ]]; then
   if [[ "$2" == "--tail" ]]; then
       docker exec -it mysql tail -10 /dump/dump.log
   else
       docker exec -it mysql tail -f /dump/dump.log
   fi
fi

if [[ "$1" == "pg-copy" ]]; then
   sudo cp docker/postgres/dump/*.dump pg_dump
fi

if [[ "$1" == "pg-log" ]]; then
   if [[ "$2" == "--tail" ]]; then
       docker exec -it postgres tail -10 /dump/dump.log
   else
       docker exec -it postgres tail -f /dump/dump.log
   fi
fi