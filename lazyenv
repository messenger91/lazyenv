    C='\033[0;36m'; B='\033[0;34m'; M='\033[0;35m'
    D='\033[2m'; N='\033[0m'
    echo -e "${R}‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ${Y}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó${G}‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó${C}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó${B}‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó${M}‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó${N}"
    echo -e "${R}‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó${Y}‚ēö‚ēź‚ēź‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ${G}‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ${C}‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ${B}‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ${M}‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ${N}"
    echo -e "${R}‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ${Y}  ‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ${G} ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ${C}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ${B}‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ${M} ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ${N}"
    echo -e "${R}‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ${Y} ‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  ${G}  ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ${C}‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ${B}‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ${M}  ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ${N}"
    echo -e "${R}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ${Y}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó${G}   ‚Ėą‚Ėą‚ēĎ   ${C}‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó${B}‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ${M}   ‚Ėą‚Ėą‚ēĎ   ${N}"
    echo -e "${R}‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ${Y}‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ${G}   ‚ēö‚ēź‚ēĚ   ${C}‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ${B}‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ${M}   ‚ēö‚ēź‚ēĚ   ${N}"
